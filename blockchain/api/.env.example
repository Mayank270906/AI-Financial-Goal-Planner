# ============================================
# GoalPath AI — Blockchain Bridge API
# ============================================

# Ethereum Sepolia RPC endpoint (public)
RPC_URL=https://sepolia.drpc.org

# Private key of the GoalPath AI operator wallet (hex with 0x prefix)
# This wallet must be the goalPathAI address set in both contracts
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Deployed contract addresses on Sepolia
PASSPORT_CONTRACT_ADDRESS=0xYOUR_PASSPORT_CONTRACT_ADDRESS
ADVISOR_CONTRACT_ADDRESS=0xYOUR_ADVISOR_CONTRACT_ADDRESS

# Shared API key for authenticating requests from the Python backend
GOALPATH_INTERNAL_KEY=GOALPATH_INTERNAL_KEY_2026

# Separate admin key for advisor verification (admin-only actions)
ADMIN_KEY=GOALPATH_ADMIN_KEY_2026

# Server port
PORT=3001

# Block explorer base URL
ETHERSCAN_BASE_URL=https://sepolia.etherscan.io

# Chain ID for Sepolia
CHAIN_ID=11155111
